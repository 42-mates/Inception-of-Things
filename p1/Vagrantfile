
LOGIN = "akurochk"
NETWORK_NAME = "fox_net"
PROVIDER = "virtualbox"
IP_SERVER = "192.168.56.110"
IP_WORKER = "192.168.56.111"
# check 512 in school
MEMORY = 1024
CPUS = 1
SCRIPT_SERVER = "scripts/server.sh"
SCRIPT_WORKER = "scripts/worker.sh"

Vagrant.configure("2") do |config|

    config.vm.box = "debian/bookworm64"
    config.vm.box_check_update = false
    config.ssh.insert_key = false
    
    # Example from subject:
    #
    # config.vm.define "wilSW" do |control|
    #     control.vm.hostname = "wilSW"
    #     control.vm.network REDACTED, ip: "192.168.56.111"
    #     control.vm.provider REDACTED do |v|
    #         v.customize ["modifyvm", :id, "--name", "wilSW"]
    #         [...]
    #     end
    #     config.vm.provision "shell", inline: <<-SHELL
    #         [..]
    #     SHELL
    # end

    config.vm.define "#{LOGIN}S" do |server|
        server.vm.hostname = "#{LOGIN}S"
        server.vm.network "#{NETWORK_NAME}", ip: "#{IP_SERVER}"
        server.vm.provider "#{PROVIDER}" do |v|
            v.customize ["modifyvm", :id, "--name", "#{LOGIN}S"]
            v.name = "#{LOGIN}S"
            v.memory = "#{MEMORY}"
            v.cpus = "#{CPUS}"
        end
        server.vm.provision "shell", inline: <<-SHELL
            # [...] bash and curl to install
        SHELL

        server.vm.provision "shell", path: "#{SCRIPT_SERVER}"
    end

    config.vm.define "#{LOGIN}SW" do |worker|
        worker.vm.hostname = "#{LOGIN}SW"
        worker.vm.network "#{NETWORK_NAME}", ip: "#{IP_WORKER}"
        worker.vm.provider "#{PROVIDER}" do |v|
            v.customize ["modifyvm", :id, "--name", "#{LOGIN}SW"]
            v.name = "#{LOGIN}SW"
            v.memory = "#{MEMORY}"
            v.cpus = "#{CPUS}"
        end
        worker.vm.provision "shell", inline: <<-SHELL
            # [...] bash and curl to install
        SHELL

        worker.vm.provision "shell", path: "#{SCRIPT_WORKER}"
    end

end
